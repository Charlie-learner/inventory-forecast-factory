# Copy this file to .env and fill in values locally. Never commit .env.
# Offline reproducible mode:
LLM_MODE=mock
MODEL=gpt-4o-mini
BASE_URL=https://api.openai.com/v1
API_KEY=
LLM_TIMEOUT_SECONDS=30

# OpenAI-compatible provider example:
# LLM_MODE=api
# MODEL=your-provider-model
# BASE_URL=https://your-provider.example/v1
# API_KEY=replace-with-a-new-local-secret

# Cainiao data is intentionally kept outside Git.
CAINIAO_ZIP_PATH=C:/Users/your-name/Downloads/CAINIAO Part II Data_20160509.zip
SAMPLE_SUBMISSION_PATH=C:/Users/your-name/Downloads/sample_submission.csv
