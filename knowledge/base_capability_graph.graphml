    <node id="algorithm:ridge_lag">
      <data key="d1">Algorithm</data>
      <data key="d2">ridge_lag</data>
      <data key="d3">Regularized autoregression over the last 14 days.</data>
      <data key="d4">30</data>
      <data key="d5">["scikit-learn"]</data>
    </node>
