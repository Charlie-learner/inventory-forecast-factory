      <data key="d2">short_history</data>
    </node>
    <node id="algorithm:moving_average">
      <data key="d1">Algorithm</data>
      <data key="d2">moving_average</data>
      <data key="d8">Uses the recent 14-day demand average.</data>
      <data key="d9">7</data>
      <data key="d10">[]</data>
      <data key="d11">non-negative daily qty_alipay_njhs history</data>
      <data key="d12">daily forecast plus horizon-total target inventory</data>
      <data key="d13">["all", "1", "2", "3", "4", "5"]</data>
    </node>
    <node id="algorithm:ridge_lag">
      <data key="d1">Algorithm</data>
      <data key="d2">ridge_lag</data>
      <data key="d8">Regularized autoregression over the last 14 days.</data>
      <data key="d9">30</data>
      <data key="d10">["scikit-learn"]</data>
      <data key="d11">non-negative daily qty_alipay_njhs history</data>
      <data key="d12">daily forecast plus horizon-total target inventory</data>
      <data key="d13">["all", "1", "2", "3", "4", "5"]</data>
