    </node>
    <node id="algorithm:last_value">
      <data key="d1">Algorithm</data>
      <data key="d2">last_value</data>
      <data key="d8">Repeats the last observed demand.</data>
      <data key="d9">1</data>
      <data key="d10">[]</data>
      <data key="d11">non-negative daily qty_alipay_njhs history</data>
      <data key="d12">daily forecast plus horizon-total target inventory</data>
      <data key="d13">["all", "1", "2", "3", "4", "5"]</data>
