{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/inventory-capability-spec.schema.json",
  "title": "Inventory Algorithm Capability Specification",
  "type": "object",
  "required": [
    "name",
    "task_type",
    "description",
    "template_name",
    "input_contract",
    "output_contract",
    "version",
    "source_type",
    "source_ref",
    "source_hash",
    "extracted_by",
    "confidence",
    "review_status"
  ],
  "properties": {
    "name": {"type": "string", "pattern": "^[A-Za-z0-9_]+$"},
    "task_type": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "template_name": {"type": "string", "minLength": 1},
    "input_contract": {"type": "string", "minLength": 1},
    "output_contract": {"type": "string", "minLength": 1},
    "suitable_for": {"type": "array", "items": {"type": "string"}},
    "metrics": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "parameters": {"type": "object"},
    "source_type": {"type": "string", "minLength": 1},
    "source_ref": {"type": "string"},
    "source_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "version": {"type": "string", "minLength": 1},
    "extracted_by": {"type": "string", "minLength": 1},
    "source_title": {"type": "string"},
    "source_url": {"type": "string"},
    "source_license": {"type": "string"},
    "accessed_at": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "review_status": {"type": "string", "minLength": 1},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "extraction_warnings": {"type": "array", "items": {"type": "string"}},
    "implementation_kind": {"type": "string", "minLength": 1},
    "entrypoints": {"type": "array", "items": {"type": "string"}},
    "internal_dependencies": {"type": "array", "items": {"type": "string"}},
    "complexity": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    }
  },
  "additionalProperties": false
}
